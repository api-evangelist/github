{
  "@context": {
    "@version": 1.1,
    "github": "https://docs.github.com/ns/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Repository": {
      "@id": "github:Repository",
      "@context": {
        "name": "schema:name",
        "full_name": "github:fullName",
        "description": "schema:description",
        "html_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "url": {
          "@id": "github:apiUrl",
          "@type": "@id"
        },
        "homepage": {
          "@id": "schema:mainEntityOfPage",
          "@type": "@id"
        },
        "owner": {
          "@id": "schema:maintainer",
          "@type": "@id"
        },
        "language": "schema:programmingLanguage",
        "topics": {
          "@id": "schema:keywords",
          "@container": "@set"
        },
        "license": "schema:license",
        "private": "github:isPrivate",
        "fork": "github:isFork",
        "archived": "github:isArchived",
        "disabled": "github:isDisabled",
        "is_template": "github:isTemplate",
        "visibility": "github:visibility",
        "default_branch": "github:defaultBranch",
        "stargazers_count": "github:stargazersCount",
        "watchers_count": "github:watchersCount",
        "forks_count": "github:forksCount",
        "open_issues_count": "github:openIssuesCount",
        "size": "schema:contentSize",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "pushed_at": {
          "@id": "github:pushedAt",
          "@type": "xsd:dateTime"
        }
      }
    },

    "User": {
      "@id": "github:User",
      "@context": {
        "login": "schema:alternateName",
        "name": "schema:name",
        "email": "schema:email",
        "bio": "schema:description",
        "company": "schema:worksFor",
        "location": "schema:homeLocation",
        "blog": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "html_url": {
          "@id": "schema:mainEntityOfPage",
          "@type": "@id"
        },
        "avatar_url": {
          "@id": "schema:image",
          "@type": "@id"
        },
        "twitter_username": "github:twitterUsername",
        "hireable": "github:isHireable",
        "public_repos": "github:publicReposCount",
        "public_gists": "github:publicGistsCount",
        "followers": "schema:follows",
        "following": "github:followingCount",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Organization": {
      "@id": "github:Organization",
      "@context": {
        "login": "schema:alternateName",
        "name": "schema:name",
        "description": "schema:description",
        "email": "schema:email",
        "location": "schema:location",
        "blog": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "html_url": {
          "@id": "schema:mainEntityOfPage",
          "@type": "@id"
        },
        "avatar_url": {
          "@id": "schema:image",
          "@type": "@id"
        },
        "company": "schema:legalName",
        "is_verified": "github:isVerified",
        "public_repos": "github:publicReposCount",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Issue": {
      "@id": "github:Issue",
      "@context": {
        "title": "schema:name",
        "body": "schema:text",
        "number": "schema:identifier",
        "state": "github:state",
        "html_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "user": {
          "@id": "schema:author",
          "@type": "@id"
        },
        "assignees": {
          "@id": "github:assignees",
          "@container": "@set"
        },
        "labels": {
          "@id": "github:labels",
          "@container": "@set"
        },
        "milestone": "github:milestone",
        "comments": "schema:commentCount",
        "locked": "github:isLocked",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "closed_at": {
          "@id": "github:closedAt",
          "@type": "xsd:dateTime"
        }
      }
    },

    "PullRequest": {
      "@id": "github:PullRequest",
      "@context": {
        "title": "schema:name",
        "body": "schema:text",
        "number": "schema:identifier",
        "state": "github:state",
        "html_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "user": {
          "@id": "schema:author",
          "@type": "@id"
        },
        "head": "github:headRef",
        "base": "github:baseRef",
        "draft": "github:isDraft",
        "merged": "github:isMerged",
        "mergeable": "github:isMergeable",
        "additions": "github:additions",
        "deletions": "github:deletions",
        "changed_files": "github:changedFiles",
        "commits": "github:commitsCount",
        "comments": "schema:commentCount",
        "review_comments": "github:reviewCommentsCount",
        "requested_reviewers": {
          "@id": "github:requestedReviewers",
          "@container": "@set"
        },
        "labels": {
          "@id": "github:labels",
          "@container": "@set"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "closed_at": {
          "@id": "github:closedAt",
          "@type": "xsd:dateTime"
        },
        "merged_at": {
          "@id": "github:mergedAt",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Commit": {
      "@id": "github:Commit",
      "@context": {
        "sha": "schema:identifier",
        "message": "schema:text",
        "html_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "author": {
          "@id": "schema:author",
          "@type": "@id"
        },
        "committer": {
          "@id": "github:committer",
          "@type": "@id"
        },
        "parents": {
          "@id": "github:parentCommits",
          "@container": "@set"
        },
        "verification": "github:verification"
      }
    },

    "Release": {
      "@id": "github:Release",
      "@context": {
        "tag_name": "schema:version",
        "name": "schema:name",
        "body": "schema:text",
        "html_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "author": {
          "@id": "schema:author",
          "@type": "@id"
        },
        "draft": "github:isDraft",
        "prerelease": "github:isPrerelease",
        "assets": {
          "@id": "github:releaseAssets",
          "@container": "@set"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "published_at": {
          "@id": "dcterms:issued",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Team": {
      "@id": "github:Team",
      "@context": {
        "name": "schema:name",
        "slug": "schema:alternateName",
        "description": "schema:description",
        "html_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "privacy": "github:privacy",
        "permission": "github:permission",
        "members_count": "github:membersCount",
        "repos_count": "github:reposCount"
      }
    },

    "Label": {
      "@id": "github:Label",
      "@context": {
        "name": "schema:name",
        "description": "schema:description",
        "color": "github:color"
      }
    },

    "Milestone": {
      "@id": "github:Milestone",
      "@context": {
        "title": "schema:name",
        "description": "schema:description",
        "state": "github:state",
        "due_on": {
          "@id": "github:dueOn",
          "@type": "xsd:dateTime"
        },
        "open_issues": "github:openIssuesCount",
        "closed_issues": "github:closedIssuesCount",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        }
      }
    },

    "WebhookEvent": {
      "@id": "github:WebhookEvent",
      "@context": {
        "action": "github:action",
        "sender": {
          "@id": "github:sender",
          "@type": "@id"
        },
        "repository": {
          "@id": "github:repository",
          "@type": "@id"
        },
        "organization": {
          "@id": "github:organization",
          "@type": "@id"
        }
      }
    }
  }
}
