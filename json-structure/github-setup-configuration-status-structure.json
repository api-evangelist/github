{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/github/refs/heads/main/json-structure/github-setup-configuration-status-structure.json",
  "name": "configuration-status",
  "description": "configuration-status from GitHub API",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "example": "open"
    },
    "progress": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "key": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "key"
        ]
      }
    }
  }
}