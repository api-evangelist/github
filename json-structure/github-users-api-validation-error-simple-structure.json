{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/github/refs/heads/main/json-structure/github-users-api-validation-error-simple-structure.json",
  "name": "validation-error-simple",
  "description": "Validation Error Simple",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "example": "Example body text"
    },
    "documentation_url": {
      "type": "string",
      "example": "https://api.github.com/repos/octocat/Hello-World"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "message",
    "documentation_url"
  ]
}