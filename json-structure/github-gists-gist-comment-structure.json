{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/github/refs/heads/main/json-structure/github-gists-gist-comment-structure.json",
  "name": "gist-comment",
  "description": "A comment made to a gist.",
  "type": "object",
  "properties": {
    "id": {
      "type": "int32",
      "example": 1
    },
    "node_id": {
      "type": "string",
      "example": "MDExOkdpc3RDb21tZW50MQ=="
    },
    "url": {
      "type": "uri",
      "example": "https://api.github.com/gists/a6db0bec360bb87e9418/comments/1"
    },
    "body": {
      "description": "The comment text.",
      "type": "string",
      "maxLength": 65535,
      "example": "Body of the attachment"
    },
    "user": {
      "$ref": "#/components/schemas/nullable-simple-user"
    },
    "created_at": {
      "type": "datetime",
      "example": "2011-04-18T23:23:56Z"
    },
    "updated_at": {
      "type": "datetime",
      "example": "2011-04-18T23:23:56Z"
    },
    "author_association": {
      "$ref": "#/components/schemas/author-association"
    }
  },
  "required": [
    "url",
    "id",
    "node_id",
    "user",
    "body",
    "author_association",
    "created_at",
    "updated_at"
  ]
}