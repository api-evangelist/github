{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/github/refs/heads/main/json-structure/github-notifications-thread-subscription-structure.json",
  "name": "thread-subscription",
  "description": "Thread Subscription",
  "type": "object",
  "properties": {
    "subscribed": {
      "type": "boolean",
      "example": true
    },
    "ignored": {
      "type": "boolean",
      "example": true
    },
    "reason": {
      "type": "string",
      "nullable": true,
      "example": "example_value"
    },
    "created_at": {
      "type": "datetime",
      "example": "2012-10-06T21:34:12Z",
      "nullable": true
    },
    "url": {
      "type": "uri",
      "example": "https://api.github.com/notifications/threads/1/subscription"
    },
    "thread_url": {
      "type": "uri",
      "example": "https://api.github.com/notifications/threads/1"
    },
    "repository_url": {
      "type": "uri",
      "example": "https://api.github.com/repos/1"
    }
  },
  "required": [
    "created_at",
    "ignored",
    "reason",
    "url",
    "subscribed"
  ]
}