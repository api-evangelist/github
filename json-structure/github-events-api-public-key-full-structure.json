{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/github/refs/heads/main/json-structure/github-events-api-public-key-full-structure.json",
  "name": "public-key-full",
  "description": "public-key-full from GitHub API",
  "type": "object",
  "properties": {
    "id": {
      "type": "int64",
      "example": 42
    },
    "key": {
      "type": "string",
      "example": "example_value"
    },
    "user_id": {
      "nullable": true,
      "type": "int32",
      "example": 42
    },
    "repository_id": {
      "nullable": true,
      "type": "int64",
      "example": 42
    },
    "url": {
      "type": "string",
      "example": "https://api.github.com/repos/octocat/Hello-World"
    },
    "title": {
      "type": "string",
      "example": "Example Title"
    },
    "read_only": {
      "type": "boolean",
      "example": true
    },
    "verified": {
      "type": "boolean",
      "example": true
    },
    "created_at": {
      "type": "datetime",
      "example": "2026-04-17T12:00:00Z"
    },
    "added_by": {
      "type": "string",
      "nullable": true,
      "example": "example_value"
    },
    "last_used": {
      "nullable": true,
      "type": "datetime",
      "example": "example_value"
    }
  },
  "required": [
    "id",
    "key",
    "url",
    "title",
    "verified",
    "created_at",
    "read_only",
    "last_used",
    "user_id",
    "repository_id"
  ]
}