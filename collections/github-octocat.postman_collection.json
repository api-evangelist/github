          "id": "89d19103-3389-4da3-9fb8-d7e235c3a157",
          "name": "GitHub Get Octocat",
          "request": {
            "name": "GitHub Get Octocat",
            "description": {
              "content": "The GitHub Octocat API endpoint allows users to retrieve an ASCII art representation of GitHub's mascot, Octocat, by sending a GET request to the /octocat path. This simple API operation returns the iconic Octocat image in text format, which can be customized with an optional query parameter to display different speech bubble messages. It's primarily used for fun, testing purposes, or as an Easter egg in applications, demonstrating GitHub's playful side while providing developers with a lighthearted way to verify API connectivity.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "octocat"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "s",
                  "value": "<string>",
                  "description": "The words to show in Octocat's speech bubble"
                }
              ],
              "variable": [
                {
                  "description": "Self-hosted Enterprise Server hostname",
                  "type": "any",
                  "value": "{{hostname}}",
                  "key": "hostname"
                },
                {
                  "description": "Self-hosted Enterprise Server protocol",
                  "type": "any",
                  "value": "{{protocol}}",
                  "key": "protocol"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/octocat-stream"
              }
            ],
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}"
                }
              ]
            }
          },
